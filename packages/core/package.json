{
  "name": "@pixieditor/core",
  "version": "0.1.0",
  "description": "PixiJS-based WebGL editor library with full interaction engine",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "pixi.js": "^8.0.0",
    "nanoid": "^5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "tsup": "^8.0.0"
  },
  "peerDependencies": {
    "pixi.js": "^8.0.0"
  }
}
